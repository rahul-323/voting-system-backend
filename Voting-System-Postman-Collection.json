    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePass123\",\n  \"phone\": \"9876543210\",\n  \"voterID\": \"ABC12345\",\n  \"userType\": \"Voter\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/auth/register",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        },
                        "description": "Register a new user (Admin or Voter)\n\nValidation Rules:\n- Name: 2-50 characters\n- Email: Valid email format\n- Password: Min 8 characters\n- Phone: Exactly 10 digits\n- Voter ID: 6-12 alphanumeric characters\n- User Type: 'Admin' or 'Voter'"
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securePass123\",\n  \"userType\": \"Voter\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:8080/api/auth/login",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Login with email and password. Returns JWT token.\n\nSave the token and use it in Authorization header for other requests:\nHeader: Authorization: Bearer {token}"
                    },
                    "response": []
                }
            ]
        },
